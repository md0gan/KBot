APP_NAME="KBot Binance TR"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Istanbul
APP_URL=http://localhost:8000

APP_LOCALE=tr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=tr_TR

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Veritabani (MySQL) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kbot
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="bot@kbot.local"
MAIL_FROM_NAME="${APP_NAME}"

# --- Binance TR / Bot varsayilanlari ---
# Bu degerler panelden (Ayarlar) da yonetilir; buradakiler sadece varsayilandir.
BINANCE_TR_BASE_URL=https://www.binance.tr
BINANCE_TR_MARKET_BASE_URL=https://api.binance.me
BINANCE_TR_RECV_WINDOW=5000

# Genel islem modu: simulation | live  (panelden degistirilebilir)
BOT_DEFAULT_MODE=simulation
# Varsayilan kote para birimi
BOT_DEFAULT_QUOTE=USDT
